{
  "name": "google-workspace-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Google Workspace APIs (Calendar, Gmail, Drive, Docs, Sheets, Slides) with OAuth2",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "google-workspace-mcp-server": "dist/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "nodemailer": "^8.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^7.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.18"
  }
}
