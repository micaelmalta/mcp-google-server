{
  "name": "google-workspace-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Google Workspace APIs (Calendar, Gmail, Drive, Docs, Sheets, Slides) with OAuth2",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "google-workspace-mcp-server": "dist/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "nodemailer": "^8.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
